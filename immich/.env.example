# Immich + zrok environment — copy to `.env` and fill in real values.
# DO NOT commit the real .env (it is gitignored).

# --- Storage locations (WSL paths; point at your data disk) ---
UPLOAD_LOCATION=/mnt/d/home-server/photos
DB_DATA_LOCATION=/mnt/d/home-server/photos/.db

# --- Immich release ---
IMMICH_VERSION=v2

# --- Postgres ---
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_HOSTNAME=database
# SECRET: generate a strong password, e.g. `openssl rand -base64 24`
DB_PASSWORD=changeme-strong-db-password

# --- zrok public share (https://<share>.share.zrok.io) ---
ZROK_SHARE_NAME=your-share-name
# SECRET: your zrok account enable token from https://api.zrok.io
ZROK_ENABLE_TOKEN=your-zrok-enable-token

# --- Hotspot (Wi-Fi SoftAP) — read by windows/scripts/start-hotspot-now.ps1 ---
# Set these as Windows env vars (or in the task) before running the hotspot script.
HOTSPOT_SSID=MyHotspot
# SECRET: WPA2 passphrase, min 8 chars
HOTSPOT_PASSPHRASE=changeme-hotspot-pass